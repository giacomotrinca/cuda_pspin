#!/bin/bash

# Scan over number of replicas, all other parameters fixed

SIZE=18
TEMP=0.5
J=1.0
ITER=10
SEED=$RANDOM
SAVE_FREQ=64
NREP_MAX=128
NSAMPLES=10
DEV=1
FMC=1 # 0: no FMC, 1: comb-like, 2: uniform
# Build list: 1, 2, 4, ..., NREP_MAX
NREP_LIST=()
NR=1
while [ $NR -le $NREP_MAX ]; do
    NREP_LIST+=($NR)
    NR=$((NR * 2))
done

echo "=== scan_nrep ==="
echo "Fixed: N=$SIZE  T=$TEMP  J=$J  iter=2^${ITER}  seed=$SEED  save_freq=$SAVE_FREQ  fmc=$FMC"
echo "Scanning nrep: ${NREP_LIST[*]}"
echo "Samples: $NSAMPLES"
echo ""

for NREP in "${NREP_LIST[@]}"; do
    for S in $(seq 0 $((NSAMPLES - 1))); do
        echo "────────────────────────────────────────"
        echo "Running nrep=$NREP  sample=$S ..."
        echo "────────────────────────────────────────"
        ./montecarlo --size=$SIZE --temp=$TEMP --J=$J --iter=$ITER --seed=$SEED --nrep=$NREP --save_freq=$SAVE_FREQ --label=$S --dev=$DEV --fmc=$FMC
        echo ""
        SEED=$((SEED + 1))
    done
done

echo "=== scan_nrep done ==="
