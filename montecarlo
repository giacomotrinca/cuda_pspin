#!/bin/bash

# Default parameters
SIZE=24
TEMP=1.0
J=1.0
ITER=14
SEED=$RANDOM
NREP=1
SAVE_FREQ=64
SHOW_OUTPUT=0
LABEL=""
DEV=""

# Parse arguments
for arg in "$@"; do
    case "$arg" in
        --size=*)  SIZE="${arg#*=}" ;;
        --temp=*)  TEMP="${arg#*=}" ;;
        --J=*)     J="${arg#*=}" ;;
        --iter=*)  ITER="${arg#*=}" ;;
        --seed=*)  SEED="${arg#*=}" ;;
        --nrep=*)  NREP="${arg#*=}" ;;
        --save_freq=*) SAVE_FREQ="${arg#*=}" ;;
        --label=*)     LABEL="${arg#*=}" ;;
        --dev=*)        DEV="${arg#*=}" ;;
        --show-output) SHOW_OUTPUT=1 ;;
        --help)
            echo "Usage: $0 [OPTIONS]"
            echo "  --size=N      Number of spins (default: $SIZE)"
            echo "  --temp=T      Temperature (default: $TEMP)"
            echo "  --J=J         Coupling scale (default: $J)"
            echo "  --iter=K      MC iterations = 2^K (default: $ITER)"
            echo "  --seed=S      RNG seed (default: $SEED)"
            echo "  --nrep=R      Number of replicas (default: $NREP)"
            echo "  --save_freq=K Save every K iterations (default: $SAVE_FREQ)"
            echo "  --label=L     Sample label (default: none)"
            echo "  --dev=D       GPU device index (default: all visible)"
            echo "  --show-output Print progress to stdout"
            exit 0
            ;;
        *)
            echo "Unknown option: $arg"
            exit 1
            ;;
    esac
done

# Compute 2^ITER
MC_ITER=$((1 << ITER))

echo "=== montecarlo launcher ==="
echo "N=$SIZE  T=$TEMP  J=$J  iter=2^${ITER}=${MC_ITER}  seed=$SEED  nrep=$NREP  save_freq=$SAVE_FREQ"
echo ""

VERBOSE_FLAG=""
if [ "$SHOW_OUTPUT" -eq 1 ]; then
    VERBOSE_FLAG="-verbose"
fi

LABEL_FLAG=""
if [ -n "$LABEL" ]; then
    LABEL_FLAG="-label $LABEL"
fi

if [ -n "$DEV" ]; then
    DEV_FLAG="-dev $DEV"
    echo "Using GPU device: $DEV"
fi

./bin/pspin24 -N "$SIZE" -T "$TEMP" -J "$J" -iter "$MC_ITER" -seed "$SEED" -nrep "$NREP" -save_freq "$SAVE_FREQ" $VERBOSE_FLAG $LABEL_FLAG $DEV_FLAG
