#!/bin/bash

# Default parameters
SIZE=24
TEMP=1.0
J=1.0
ITER=14
SEED=$RANDOM
NREP=1
SAVE_FREQ=64
SHOW_OUTPUT=0
LABEL=""
DEV=""
FMC=""

# Parse arguments
for arg in "$@"; do
    case "$arg" in
        --size=*)  SIZE="${arg#*=}" ;;
        --temp=*)  TEMP="${arg#*=}" ;;
        --J=*)     J="${arg#*=}" ;;
        --iter=*)  ITER="${arg#*=}" ;;
        --seed=*)  SEED="${arg#*=}" ;;
        --nrep=*)  NREP="${arg#*=}" ;;
        --save_freq=*) SAVE_FREQ="${arg#*=}" ;;
        --label=*)     LABEL="${arg#*=}" ;;
        --dev=*)        DEV="${arg#*=}" ;;
        --fmc=*)        FMC="${arg#*=}" ;;
        --show-output) SHOW_OUTPUT=1 ;;
        --help)
            echo "Usage: $0 [OPTIONS]"
            echo "  --size=N      Number of spins (default: $SIZE)"
            echo "  --temp=T      Temperature (default: $TEMP)"
            echo "  --J=J         Coupling scale (default: $J)"
            echo "  --iter=K      MC iterations = 2^K (default: $ITER)"
            echo "  --seed=S      RNG seed (default: $SEED)"
            echo "  --nrep=R      Number of replicas (default: $NREP)"
            echo "  --save_freq=K Save every K iterations (default: $SAVE_FREQ)"
            echo "  --label=L     Sample label (default: none)"
            echo "  --dev=D       GPU device index (default: all visible)"
            echo "  --fmc=M       FMC mode: 0=FC, 1=comb, 2=uniform (default: 0)"
            echo "  --show-output Print progress to stdout"
            exit 0
            ;;
        *)
            echo "Unknown option: $arg"
            exit 1
            ;;
    esac
done

# Compute 2^ITER
MC_ITER=$((1 << ITER))

echo ""
echo "╔══════════════════════════════════════════════════╗"
echo "║            p-Spin 2+4 :: Monte Carlo             ║"
echo "╚══════════════════════════════════════════════════╝"
printf "  %-22s %s\n" "N" "$SIZE"
printf "  %-22s %s\n" "nrep" "$NREP"
printf "  %-22s %s\n" "T" "$TEMP"
printf "  %-22s %s\n" "J" "$J"
printf "  %-22s %s  (2^%s)\n" "sweeps" "$MC_ITER" "$ITER"
printf "  %-22s %s\n" "save_freq" "$SAVE_FREQ"
printf "  %-22s %s\n" "seed" "$SEED"
if [ -n "$DEV" ]; then printf "  %-22s %s\n" "GPU device" "$DEV"; fi
if [ -n "$FMC" ]; then printf "  %-22s %s\n" "FMC mode" "$FMC"; fi
echo ""

VERBOSE_FLAG=""
if [ "$SHOW_OUTPUT" -eq 1 ]; then
    VERBOSE_FLAG="-verbose"
fi

LABEL_FLAG=""
if [ -n "$LABEL" ]; then
    LABEL_FLAG="-label $LABEL"
fi

DEV_FLAG=""
if [ -n "$DEV" ]; then
    DEV_FLAG="-dev $DEV"
fi

FMC_FLAG=""
if [ -n "$FMC" ]; then
    FMC_FLAG="-fmc $FMC"
fi

./bin/pspin24 -N "$SIZE" -T "$TEMP" -J "$J" -iter "$MC_ITER" -seed "$SEED" -nrep "$NREP" -save_freq "$SAVE_FREQ" $VERBOSE_FLAG $LABEL_FLAG $DEV_FLAG $FMC_FLAG
