#!/bin/bash

# Launch multiple independent samples of parallel tempering
# Each sample uses a different seed (= different disorder realisation)

# Default parameters
SIZE=18
TMAX=1.6
TMIN=0.1
NT=36
J=1.0
ITER=19
SEED=$RANDOM
NREP=4
PT_FREQ=64
SAVE_FREQ=256
NSAMPLES=5
DEV=0
FMC=1
GAMMA=""
SHOW_OUTPUT=0
LOG_TEMP=0

# Parse arguments
for arg in "$@"; do
    case "$arg" in
        --size=*)      SIZE="${arg#*=}" ;;
        --tmax=*)      TMAX="${arg#*=}" ;;
        --tmin=*)      TMIN="${arg#*=}" ;;
        --nt=*)        NT="${arg#*=}" ;;
        --J=*)         J="${arg#*=}" ;;
        --iter=*)      ITER="${arg#*=}" ;;
        --seed=*)      SEED="${arg#*=}" ;;
        --nrep=*)      NREP="${arg#*=}" ;;
        --pt_freq=*)   PT_FREQ="${arg#*=}" ;;
        --save_freq=*) SAVE_FREQ="${arg#*=}" ;;
        --nsamples=*)  NSAMPLES="${arg#*=}" ;;
        --dev=*)       DEV="${arg#*=}" ;;
        --fmc=*)       FMC="${arg#*=}" ;;
        --gamma=*)     GAMMA="${arg#*=}" ;;
        --show-output=*) SHOW_OUTPUT="${arg#*=}" ;;
        --log-temp)    LOG_TEMP=1 ;;
        --help)
            echo "Usage: $0 [OPTIONS]"
            echo "  --size=N        Number of spins (default: $SIZE)"
            echo "  --tmax=T        Max temperature (default: $TMAX)"
            echo "  --tmin=T        Min temperature (default: $TMIN)"
            echo "  --nt=N          Number of temperatures (default: $NT)"
            echo "  --J=J           Coupling scale (default: $J)"
            echo "  --iter=K        MC sweeps = 2^K (default: $ITER)"
            echo "  --seed=S        Initial RNG seed (default: random)"
            echo "  --nrep=R        Independent copies per temperature (default: $NREP)"
            echo "  --pt_freq=P     Propose exchanges every P sweeps (default: $PT_FREQ)"
            echo "  --save_freq=K   Save every K sweeps (default: $SAVE_FREQ)"
            echo "  --nsamples=S    Number of disorder samples (default: $NSAMPLES)"
            echo "  --dev=D         GPU device index (default: $DEV)"
            echo "  --fmc=M         FMC mode: 0=FC, 1=comb, 2=uniform (default: $FMC)"
            echo "  --gamma=G       FMC gamma (default: auto)"
            echo "  --show-output=L Verbosity: 0=silent 1=compact 2=detailed (default: $SHOW_OUTPUT)"
            echo "  --log-temp      Geometric temperature schedule: T_k = A*T_{k-1} (default: linear)"
            exit 0
            ;;
        *)
            echo "Unknown option: $arg"
            exit 1
            ;;
    esac
done

SWEEPS=$((1 << ITER))
TOTAL_REPLICAS=$((NT * NREP))

echo ""
echo "╔══════════════════════════════════════════════════╗"
echo "║         p-Spin 2+4 :: Scan Samples (PT)          ║"
echo "╚══════════════════════════════════════════════════╝"
printf "  %-22s %s\n" "N" "$SIZE"
printf "  %-22s %s\n" "NT" "$NT"
printf "  %-22s %s\n" "nrep/T" "$NREP"
printf "  %-22s %s\n" "total replicas" "$TOTAL_REPLICAS"
printf "  %-22s %s\n" "Tmax" "$TMAX"
printf "  %-22s %s\n" "Tmin" "$TMIN"
printf "  %-22s %s\n" "J" "$J"
printf "  %-22s %s  (2^%s)\n" "sweeps" "$SWEEPS" "$ITER"
printf "  %-22s %s\n" "pt_freq" "$PT_FREQ"
printf "  %-22s %s\n" "save_freq" "$SAVE_FREQ"
printf "  %-22s %s\n" "samples" "$NSAMPLES"
printf "  %-22s %s\n" "seed (initial)" "$SEED"
printf "  %-22s %s\n" "GPU device" "$DEV"
if [ -n "$FMC" ]; then printf "  %-22s %s\n" "FMC mode" "$FMC"; fi
if [ "$LOG_TEMP" -eq 1 ]; then printf "  %-22s %s\n" "T schedule" "geometric"; else printf "  %-22s %s\n" "T schedule" "linear"; fi
echo ""

for S in $(seq 0 $((NSAMPLES - 1))); do
    printf "── Sample %d/%d (seed=%s) " "$S" "$((NSAMPLES - 1))" "$SEED"
    printf '─%.0s' $(seq 1 28)
    printf "\n"
    ./parallel_tempering --size=$SIZE --tmax=$TMAX --tmin=$TMIN --nt=$NT --J=$J --iter=$ITER --seed=$SEED --nrep=$NREP --pt_freq=$PT_FREQ --save_freq=$SAVE_FREQ --label=$S --dev=$DEV --fmc=$FMC ${GAMMA:+--gamma=$GAMMA} --show-output=$SHOW_OUTPUT $([ "$LOG_TEMP" -eq 1 ] && echo "--log-temp")
    echo ""
    SEED=$RANDOM
done

echo "── Done ─────────────────────────────────────────────"
echo "  All $NSAMPLES samples completed."
echo ""
