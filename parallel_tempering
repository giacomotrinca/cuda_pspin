#!/bin/bash

# Default parameters
SIZE=18
TMAX=2.0
TMIN=0.01
NT=20
J=2.0
J0=0.0
ALPHA=0.5
ALPHA0=0.5
ITER=14
SEED=$RANDOM
NREP=2
PT_FREQ=1
SAVE_FREQ=64
SHOW_OUTPUT=0
LABEL=""
DEV=0
FMC=1
GAMMA=""
LOG_TEMP=0

# Parse arguments
for arg in "$@"; do
    case "$arg" in
        --size=*)      SIZE="${arg#*=}" ;;
        --tmax=*)      TMAX="${arg#*=}" ;;
        --tmin=*)      TMIN="${arg#*=}" ;;
        --nt=*)        NT="${arg#*=}" ;;
        --J=*)         J="${arg#*=}" ;;
        --J0=*)        J0="${arg#*=}" ;;
        --alpha=*)     ALPHA="${arg#*=}" ;;
        --alpha0=*)    ALPHA0="${arg#*=}" ;;
        --iter=*)      ITER="${arg#*=}" ;;
        --seed=*)      SEED="${arg#*=}" ;;
        --nrep=*)      NREP="${arg#*=}" ;;
        --pt_freq=*)   PT_FREQ="${arg#*=}" ;;
        --save_freq=*) SAVE_FREQ="${arg#*=}" ;;
        --label=*)     LABEL="${arg#*=}" ;;
        --dev=*)       DEV="${arg#*=}" ;;
        --fmc=*)       FMC="${arg#*=}" ;;
        --gamma=*)     GAMMA="${arg#*=}" ;;
        --show-output=*) SHOW_OUTPUT="${arg#*=}" ;;
        --log-temp)    LOG_TEMP=1 ;;
        --help)
            echo "Usage: $0 [OPTIONS]"
            echo "  --size=N        Number of spins (default: $SIZE)"
            echo "  --tmax=T        Max temperature (default: $TMAX)"
            echo "  --tmin=T        Min temperature (default: $TMIN)"
            echo "  --nt=N          Number of temperatures (default: $NT)"
            echo "  --J=J           Total coupling scale (default: $J)"
            echo "  --J0=J0         Mean coupling scale (default: $J0)"
            echo "  --alpha=A       4-body fraction of J: J4=a*J, J2=(1-a)*J (default: $ALPHA)"
            echo "  --alpha0=A0     4-body fraction of J0 (default: $ALPHA0)"
            echo "  --iter=K        MC sweeps = 2^K (default: $ITER)"
            echo "  --seed=S        RNG seed (default: random)"
            echo "  --nrep=R        Independent copies per temperature (default: $NREP)"
            echo "  --pt_freq=P     Propose exchanges every P sweeps (default: $PT_FREQ)"
            echo "  --save_freq=K   Save every K sweeps (default: $SAVE_FREQ)"
            echo "  --label=L       Sample label (default: none)"
            echo "  --dev=D         GPU device index (default: $DEV)"
            echo "  --fmc=M         FMC mode: 0=FC, 1=comb, 2=uniform (default: $FMC)"
            echo "  --gamma=G       FMC gamma (default: auto)"
            echo "  --show-output=L Verbosity: 0=silent 1=compact 2=detailed (default: $SHOW_OUTPUT)"
            echo "  --log-temp      Geometric temperature schedule: T_k = A*T_{k-1} (default: linear)"
            exit 0
            ;;
        *)
            echo "Unknown option: $arg"
            exit 1
            ;;
    esac
done

# Compute 2^ITER
MC_ITER=$((1 << ITER))
TOTAL_REPLICAS=$((NT * NREP))

echo ""
echo "╔══════════════════════════════════════════════════╗"
echo "║         p-Spin 2+4 :: Parallel Tempering         ║"
echo "╚══════════════════════════════════════════════════╝"
printf "  %-22s %s\n" "N" "$SIZE"
printf "  %-22s %s\n" "NT" "$NT"
printf "  %-22s %s\n" "nrep/T" "$NREP"
printf "  %-22s %s\n" "total replicas" "$TOTAL_REPLICAS"
printf "  %-22s %s\n" "Tmax" "$TMAX"
printf "  %-22s %s\n" "Tmin" "$TMIN"
printf "  %-22s %s\n" "J" "$J"
printf "  %-22s %s\n" "J0" "$J0"
printf "  %-22s %s\n" "alpha" "$ALPHA"
printf "  %-22s %s\n" "alpha0" "$ALPHA0"
printf "  %-22s %s  (2^%s)\n" "sweeps" "$MC_ITER" "$ITER"
printf "  %-22s %s\n" "pt_freq" "$PT_FREQ"
printf "  %-22s %s\n" "save_freq" "$SAVE_FREQ"
printf "  %-22s %s\n" "seed" "$SEED"
if [ -n "$DEV" ]; then printf "  %-22s %s\n" "GPU device" "$DEV"; fi
if [ -n "$FMC" ]; then printf "  %-22s %s\n" "FMC mode" "$FMC"; fi
if [ "$LOG_TEMP" -eq 1 ]; then printf "  %-22s %s\n" "T schedule" "geometric"; else printf "  %-22s %s\n" "T schedule" "linear"; fi
echo ""

VERBOSE_FLAG=""
if [ "$SHOW_OUTPUT" -gt 0 ]; then
    VERBOSE_FLAG="-verbose $SHOW_OUTPUT"
fi

LABEL_FLAG=""
if [ -n "$LABEL" ]; then
    LABEL_FLAG="-label $LABEL"
fi

DEV_FLAG=""
if [ -n "$DEV" ]; then
    DEV_FLAG="-dev $DEV"
fi

FMC_FLAG=""
if [ -n "$FMC" ]; then
    FMC_FLAG="-fmc $FMC"
fi

GAMMA_FLAG=""
if [ -n "$GAMMA" ]; then
    GAMMA_FLAG="-gamma $GAMMA"
fi

LOG_TEMP_FLAG=""
if [ "$LOG_TEMP" -eq 1 ]; then
    LOG_TEMP_FLAG="-log_temp"
fi

./bin/parallel_tempering \
    -N "$SIZE" \
    -Tmax "$TMAX" -Tmin "$TMIN" -NT "$NT" \
    -J "$J" \
    -J0 "$J0" -alpha "$ALPHA" -alpha0 "$ALPHA0" \
    -iter "$MC_ITER" \
    -seed "$SEED" \
    -nrep "$NREP" \
    -pt_freq "$PT_FREQ" \
    -save_freq "$SAVE_FREQ" \
    $VERBOSE_FLAG $LABEL_FLAG $DEV_FLAG $FMC_FLAG $GAMMA_FLAG $LOG_TEMP_FLAG
